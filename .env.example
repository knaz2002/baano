APP_NAME=Baano
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (дамп с прода → baano_db, migrate не нужен) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=baano_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
# Локально по умолчанию: log → письма пишутся в storage/logs/laravel.log.
# Реальная отправка: MAIL_MAILER=smtp, MAIL_SCHEME=smtps, MAIL_HOST=smtp.timeweb.ru,
# MAIL_PORT=465, MAIL_USERNAME / MAIL_PASSWORD (ящик support@baano.ru), остальные FROM как ниже.
# MAIL_DEBUG_TO — не production: все письма уходят на этот адрес (удобно при фейковых email в регистрации).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@baano.ru"
MAIL_FROM_NAME="Baano"
MAIL_DEBUG_TO=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- SMS verification (телефон → потом email) ---
# log   — код в laravel.log (+ Dev only на /verify-phone при APP_ENV=local)
# mail  — код письмом: SMS_DEBUG_MAIL, если пусто — берётся MAIL_DEBUG_TO
# smsru — SMS.ru (SMS_RU_API_ID; SMS_RU_TEST=true = без списания)
SMS_DRIVER=log
SMS_DEBUG_MAIL=
SMS_RU_API_ID=
SMS_RU_TEST=true
SMS_SENDER=

# Опционально (Telegram / Web Push) — для SMS-проверки не нужны
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
VAPID_SUBJECT=mailto:admin@baano.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=